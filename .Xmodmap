! run `xmodmap -pm` to get existing modifiers status

!
! Swap Control_L and Super_L
!
remove control = Control_L
add mod4 = Control_L
remove mod4 = Super_L
add control = Super_L

!
! Swap Alt_R and Super_R
!
remove mod1 = Alt_R
add mod4 = Alt_R
remove mod4 = Super_R
add mod1 = Super_R

!
! Make Caps_Lock and sdditional control
!
remove lock = Caps_Lock
keysym Caps_Lock = Control_L
add control = Caps_Lock
