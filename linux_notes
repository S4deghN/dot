# less key-repeat delay and higher key-repeat rate
xset r rate 250 45

# if experiencing slow internet and timeouts with wifi.
sudo vim /etc/gai.conf # Locate "#precedence ::ffff:0:0/96 100" and and remove the #.
sudo vim /etc/NetworkManager/conf.d/default-wifi-powersave-on.conf # change power saving option from 3 to 2.

# append a user to a group.
# for usb access on arch use uucp group and dialout on deb
sudo usermod -aG [group] [user]

# if you have a hanging internet, you might be using a broken DNS.
dig csclub.uwaterloo.ca
dig @8.8.8.8 dig csclub.uwaterloo.ca
getent hosts csclub.uwaterloo.ca
nslookup csclub.uwaterloo.ca
stat /etc/resolv.conf
cat /etc/resolv.conf
cat /etc/nsswitch.conf

# Alacritty doesn't support tabs, it's recommended to use it with Tmux. 
# to run alacritty with a command use -e (e.g., alacritty -e tmux).
# this command runs alacritty with the latest available Tmux session if avialable othewise create one.
alacritty -e sh -c "tmux attach || tmux"

# To exclude a file from the git tree that has been tracked before but you want it to be ignored now after adding it to your .gitignore file you can run these commands
# for a file:
git rm --cached file.log
# and for a directory:
git rm --cached -r directory
