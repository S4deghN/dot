            if strlen(s) < 2 || s =~? '"\([\~\/]\|\S\+\/\)\S\+"\s.*'
                echomsg $'used {cmd}'
                break
            endif
        catch
            # echomsg $'we catched on: {cmd}: {v:exception}'
            continue
        endtry
    endfor
enddef

