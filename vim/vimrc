        'echo "unbind(change)+change-prompt({q}> )+enable-search+transform-query:echo \{q} > /tmp/rg-fzf-r; cat /tmp/rg-fzf-f"'
    ]}
    call fzf#vim#grep(initial_grep, 1, fzf#vim#with_preview(options), fullscreen)
