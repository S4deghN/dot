# --- delete ---
def Delete(op: string, type: string)
    Operate(op, type)
    if reltime(get(g:, 'last_del_time', [0, 0]))[0] < 3 # less than 3 sec
        setreg("D", getreg('@'))
    else
        setreg("d", getreg('@'))
    endif
    g:last_del_time = reltime()
enddef
