def JumpToDefinition()
    var fallbacks = [
        'LspGotoDefinition',
        'call JumpTag()',
        'normal! gd',
        'normal! [\<C-I>',
    ]

    for cmd in fallbacks
        try
            var s = execute(cmd)
            # echomsg $'s: {s}'
            if strlen(s) < 2 || s =~? '"\([\~\/]\|\S\+\/\)\S\+"\s.*'
                echomsg $'used {cmd}'
                break
            endif
        catch
            # echomsg $'we catched on: {cmd}: {v:exception}'
            continue
        endtry
    endfor
enddef

def SplitJumpToDefinition()
    execute 'split g:JumpToDefinition()'
    g:MoveOpenedWinodwToSaneSplit()
enddef # }}}
